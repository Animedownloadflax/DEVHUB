rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /profiles/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /job_posts/{documentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /community_posts/{documentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /code_posts/{documentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /video_posts/{documentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.author_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }
  }
}
